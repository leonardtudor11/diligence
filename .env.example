# Diligence — service credentials
# Copy to .env and fill in. .env is gitignored.

# Google Cloud / Vertex AI — auth is via `gcloud auth print-access-token`,
# not via env var. These project IDs are read by vertex_client.py.
GCP_PROJECT_ID=project-2be42b84-14e0-421a-b3a
GCP_LOCATION=global

# Speechmatics — batch transcription with diarization
SPEECHMATICS_API_KEY=

# Featherless — Qwen3 family for Bull/Bear adversarial agents
FEATHERLESS_API_KEY=

# Financial Modeling Prep — free tier fundamentals
FMP_API_KEY=

# SEC EDGAR — no key, just a User-Agent (required by EDGAR ToS)
SEC_USER_AGENT="Diligence Hackathon contact@example.com"
